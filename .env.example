# humor_saver 환경 변수
# .env.example → .env 로 복사 후 채우기

# ─── PostgreSQL ────────────────────────────────
POSTGRES_USER=humor
POSTGRES_PASSWORD=                # ← 강력한 패스워드 설정
POSTGRES_DB=humor

# ─── Qdrant ────────────────────────────────────
QDRANT_API_KEY=

# ─── TEI (임베딩, 다국어) ───────────────────────
# multilingual-e5: 영어/한국어/일본어/중국어 의미 매칭 (apple ↔ 사과 OK)
EMBEDDING_MODEL=BAAI/bge-m3

# ─── 수집 주기 (croner 6필드: 초 분 시 일 월 요일) ─
COLLECT_CRON=0 */15 * * * *       # 15분마다 — 유머 사이트는 변동 적어 자주 안 해도 됨

# ─── NLP ───────────────────────────────────────
NLP_INTERVAL_SEC=300
NLP_BATCH_SIZE=20

# ─── 번역 (선택) ────────────────────────────────
# DeepL: 무료 50만글자/월 (https://www.deepl.com/pro-api)
DEEPL_API_KEY=
# Claude (DeepL 한도 초과 또는 미사용 시 폴백)
ANTHROPIC_API_KEY=

# ─── 매체 자동 발견 ────────────────────────────
DISCOVERER_TIME=04:00             # news_saver(03:00)와 분리
DISCOVERER_RUN_ON_BOOT=false

# ─── API ───────────────────────────────────────
API_PORT=18081

# ─── Web ───────────────────────────────────────
WEB_PORT=5174
WEB_ORIGIN=http://localhost:5174

# 관리자 페이지(/sources) 접근 허용 IP
HOME_IPS=

# 사이트 전체 비밀번호 (외부 접속 시 필요)
SITE_PASSWORD=
